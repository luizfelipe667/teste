<!DOCTYPE html>
<html lang="pt-br">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
    <title>Moto Trial 2D</title>
    <style>
        body { margin: 0; padding: 0; overflow: hidden; background: #222; font-family: sans-serif; }
        canvas { display: block; background: linear-gradient(#87CEEB, #E0F6FF); }
        #controles {
            position: absolute;
            bottom: 30px;
            width: 100%;
            display: flex;
            justify-content: space-around;
            pointer-events: none;
        }
        .btn {
            width: 70px;
            height: 70px;
            background: rgba(0, 0, 0, 0.5);
            color: white;
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 12px;
            font-weight: bold;
            user-select: none;
            pointer-events: auto;
            border: 2px solid white;
        }
        .btn:active { background: rgba(255, 255, 255, 0.3); }
    </style>
</head>
<body>

    <canvas id="game"></canvas>
    
    <div id="controles">
        <div class="btn" id="btnEsq">TRAVAR</div>
        <div class="btn" id="btnDir">ACELERAR</div>
    </div>

<script>
const canvas = document.getElementById('game');
const ctx = canvas.getContext('2d');

// Ajuste de tela
function resize() {
    canvas.width = window.innerWidth;
    canvas.height = window.innerHeight;
}
window.onresize = resize;
resize();

// Variáveis do Jogador
let moto = {
    x: 100,
    y: 200,
    vX: 0,
    vY: 0,
    rot: 0,
    vRot: 0,
    size: 40
};

let gravity = 0.25;
let friction = 0.98;
let groundY = canvas.height - 80;
let acelerando = false;
let freando = false;

// Eventos Mobile
const btnDir = document.getElementById('btnDir');
const btnEsq = document.getElementById('btnEsq');

btnDir.ontouchstart = (e) => { e.preventDefault(); acelerando = true; };
btnDir.ontouchend = () => acelerando = false;
btnEsq.ontouchstart = (e) => { e.preventDefault(); freando = true; };
btnEsq.ontouchend = () => freando = false;

// Suporte para Teclado (PC)
window.onkeydown = (e) => {
    if(e.key === "ArrowRight") acelerando = true;
    if(e.key === "ArrowLeft") freando = true;
};
window.onkeyup = (e) => {
    if(e.key === "ArrowRight") acelerando = false;
    if(e.key === "ArrowLeft") freando = false;
};

function loop() {
    // Lógica de Movimento
    moto.vY += gravity;
    
    if (acelerando) {
        moto.vX += 0.4;
        moto.vRot += 0.005;
    }
    if (freando) {
        moto.vX *= 0.95;
        moto.vRot -= 0.008;
    }

    moto.x += moto.vX;
    moto.y += moto.vY;
    moto.rot += moto.vRot;

    moto.vX *= friction;
    moto.vRot *= 0.95;

    // Colisão com o chão
    if (moto.y + 10 > groundY) {
        moto.y = groundY - 10;
        moto.vY = 0;
        
        // Se cair de cabeça (rotação errada)
        if (Math.abs(moto.rot) > 1.2) {
            moto.x = 100;
            moto.vX = 0;
            moto.rot = 0;
        }
    }

    // Loop do cenário (câmera simples)
    if (moto.x > canvas.width) moto.x = 0;
    if (moto.x < 0) moto.x = canvas.width;

    desenhar();
    requestAnimationFrame(loop);
}

function desenhar() {
    ctx.clearRect(0, 0, canvas.width, canvas.height);

    // Chão
    ctx.fillStyle = "#444";
    ctx.fillRect(0, groundY, canvas.width, 80);
